{
  "manifest_version": 3,
  "name": "Emberi Hang",
  "version": "0.4.2.3",
  "description": "Empatikus szabályalapú védelem Szabálylabor ruleset.js elsődleges pattern-adapterrel.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.hirado.hu/*",
        "https://*.mediaklikk.hu/*",
        "https://*.index.hu/*",
        "https://*.origo.hu/*",
        "https://*.hvg.hu/*",
        "https://*.444.hu/*",
        "https://*.telex.hu/*",
        "https://*.magyarnemzet.hu/*",
        "https://*.mno.hu/*",
        "https://*.portfolio.hu/*",
        "https://*.facebook.com/*",
        "https://*.youtube.com/*",
        "https://*.reddit.com/*",
        "https://*.x.com/*",
        "https://*.twitter.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "ruleset.js",
        "hatter.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "EMBERI HANG",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}